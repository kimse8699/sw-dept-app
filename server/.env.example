# ───────────────────────────────────────────────────────
# 이 파일을 복사해서 .env 로 만들고 값을 채워주세요
# cp .env.example .env
# ───────────────────────────────────────────────────────

PORT=3000

# MySQL 데이터베이스 설정
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sw_dept
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT 시크릿 키 (길고 복잡한 랜덤 문자열로 설정)
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
