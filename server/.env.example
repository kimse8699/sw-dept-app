# ───────────────────────────────────────────────────────
# 이 파일을 복사해서 .env 로 만들고 값을 채워주세요
# cp .env.example .env
# ───────────────────────────────────────────────────────

PORT=3000

# Firebase Admin SDK 서비스 계정 키
# 발급 방법:
#   Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 →
#   "새 비공개 키 생성" → 다운로드한 JSON 파일 경로 입력
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# 또는 JSON 내용을 직접 환경변수로 넣는 방법 (배포 환경 권장)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
